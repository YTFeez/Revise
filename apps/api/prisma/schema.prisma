// Revise+ - schema Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GradeLevel {
  SIXIEME // 6e
  CINQUIEME // 5e
  QUATRIEME // 4e
  TROISIEME // 3e
}

enum QuizType {
  QUIZ
  EVAL
}

enum QuestionType {
  QCM
  VRAI_FAUX
  TEXTE
}

enum CosmeticType {
  BORDER
  HAT
  BG
  BADGE
}

enum XpSource {
  QUIZ
  EVAL
  STREAK
  ADMIN
  BONUS
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  username         String          @unique
  passwordHash     String
  isAdmin          Boolean         @default(false)
  totalXp          Int             @default(0)
  level            Int             @default(1)
  coins            Int             @default(0)
  weeklyXp         Int             @default(0)
  weekResetAt      DateTime        @default(now())
  streakDays       Int             @default(0)
  lastStreakAt     DateTime?
  gradeLevel       GradeLevel?
  equippedBorder   String?
  equippedHat      String?
  equippedBg       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  attempts         Attempt[]
  xpEvents         XpEvent[]
  cosmetics        UserCosmetic[]
  subjectStats     UserSubjectStat[]
}

model Subject {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String?
  color     String?
  gradeLevel GradeLevel
  order     Int      @default(0)

  courses   Course[]
  stats     UserSubjectStat[]
}

model UserSubjectStat {
  id         String  @id @default(cuid())
  userId     String
  subjectId  String
  totalXp    Int     @default(0)
  level      Int     @default(1)
  cardCount  Int     @default(0)

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
}

model Course {
  id              String   @id @default(cuid())
  subjectId       String
  title           String
  slug            String
  contentMarkdown String   @db.Text
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  quizzes Quiz[]

  @@unique([subjectId, slug])
}

model Quiz {
  id           String     @id @default(cuid())
  courseId     String
  title        String
  type         QuizType   @default(QUIZ)
  timeLimitSec Int        @default(300)
  difficulty   Int        @default(1)
  passingScore Int        @default(50)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  Attempt[]
}

model Question {
  id      String       @id @default(cuid())
  quizId  String
  text    String       @db.Text
  type    QuestionType @default(QCM)
  points  Int          @default(1)
  order   Int          @default(0)

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]
}

model Answer {
  id         String  @id @default(cuid())
  questionId String
  text       String  @db.Text
  isCorrect  Boolean @default(false)
  order      Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Attempt {
  id             String    @id @default(cuid())
  userId         String
  quizId         String
  startedAt      DateTime  @default(now())
  expiresAt      DateTime
  completedAt    DateTime?
  scorePct       Int?
  correctCount   Int?
  totalQuestions Int?
  durationSec    Int?
  xpGained       Int?
  coinsGained    Int?
  answersJson    Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  source    XpSource
  amount    Int
  meta      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Cosmetic {
  id            String       @id @default(cuid())
  slug          String       @unique
  name          String
  type          CosmeticType
  description   String?
  priceCoins    Int          @default(0)
  requiredLevel Int          @default(1)
  assetUrl      String?
  borderClass   String?
  rarity        String       @default("common")

  ownedBy UserCosmetic[]
}

model UserCosmetic {
  id         String   @id @default(cuid())
  userId     String
  cosmeticId String
  acquiredAt DateTime @default(now())
  equipped   Boolean  @default(false)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmetic Cosmetic @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)

  @@unique([userId, cosmeticId])
}
