// Revise+ - schema Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GradeLevel {
  SIXIEME // 6e
  CINQUIEME // 5e
  QUATRIEME // 4e
  TROISIEME // 3e
}

enum QuizType {
  QUIZ
  EVAL
}

enum QuestionType {
  QCM
  VRAI_FAUX
  TEXTE
}

enum CosmeticType {
  BORDER
  HAT
  BG
  APP_BG
  BADGE
}

enum XpSource {
  QUIZ
  EVAL
  STREAK
  ADMIN
  BONUS
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum AuditAction {
  LOGIN
  REGISTER
  QUIZ_START
  QUIZ_SUBMIT
  COSMETIC_PURCHASE
  FRIEND_REQUEST
  FRIEND_ACCEPT
  FRIEND_REMOVE
  DUEL_CREATE
  DUEL_FINISH
  ADMIN_ACTION
  BAN
  UNBAN
}

enum BanType {
  TIMEOUT
  BAN
}

enum DuelStatus {
  PENDING
  ACTIVE
  FINISHED
  CANCELLED
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  username         String          @unique
  passwordHash     String
  isAdmin          Boolean         @default(false)
  totalXp          Int             @default(0)
  level            Int             @default(1)
  coins            Int             @default(0)
  weeklyXp         Int             @default(0)
  weekResetAt      DateTime        @default(now())
  streakDays       Int             @default(0)
  lastStreakAt     DateTime?
  gradeLevel       GradeLevel?
  equippedBorder   String?
  equippedHat      String?
  equippedBg       String?
  equippedAppBg    String?
  avatarJson       Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  attempts         Attempt[]
  xpEvents         XpEvent[]
  cosmetics        UserCosmetic[]
  subjectStats     UserSubjectStat[]
  auditLogs        AuditLog[]
  bans             Ban[]           @relation("BanTarget")
  issuedBans       Ban[]           @relation("BanActor")
  friendRequestsOut FriendRequest[] @relation("FriendRequestSender")
  friendRequestsIn  FriendRequest[] @relation("FriendRequestReceiver")
  friendshipsA     Friendship[]    @relation("FriendshipA")
  friendshipsB     Friendship[]    @relation("FriendshipB")
  duelHosts        Duel[]          @relation("DuelHost")
  duelGuests       Duel[]          @relation("DuelGuest")
  devices          UserDevice[]
  purchases        Purchase[]
}

model UserDevice {
  id          String   @id @default(cuid())
  userId      String
  fingerprint String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  ipHash      String?
  userAgent   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId])
}

model FriendRequest {
  id         String           @id @default(cuid())
  fromUserId String
  toUserId   String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  fromUser User @relation("FriendRequestSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("FriendRequestReceiver", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  userA User @relation("FriendshipA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendshipB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model Duel {
  id          String     @id @default(cuid())
  hostUserId  String
  guestUserId String?
  status      DuelStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  // si le duel est un quiz commun
  quizId      String?
  hostScorePct Int?
  guestScorePct Int?

  hostUser  User @relation("DuelHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  guestUser User? @relation("DuelGuest", fields: [guestUserId], references: [id], onDelete: SetNull)

  quiz Quiz? @relation(fields: [quizId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([hostUserId])
  @@index([guestUserId])
}

model ShopRotation {
  id        String   @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())

  listings ShopListing[]

  @@unique([startsAt, endsAt])
  @@index([startsAt, endsAt])
}

model ShopListing {
  id          String   @id @default(cuid())
  rotationId  String
  cosmeticId  String
  priceCoins  Int
  featured    Boolean  @default(false)
  stock       Int?     // null = illimite
  sold        Int      @default(0)

  rotation ShopRotation @relation(fields: [rotationId], references: [id], onDelete: Cascade)
  cosmetic Cosmetic     @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)

  @@unique([rotationId, cosmeticId])
  @@index([rotationId])
}

model Purchase {
  id          String   @id @default(cuid())
  userId      String
  cosmeticId  String
  priceCoins  Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmetic Cosmetic @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  ipHash    String?
  userAgent String?
  meta      Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([userId, createdAt])
}

model Ban {
  id        String   @id @default(cuid())
  type      BanType
  reason    String?
  startsAt  DateTime @default(now())
  endsAt    DateTime?
  createdAt DateTime @default(now())

  targetUserId String
  actorUserId  String?

  targetUser User @relation("BanTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  actorUser  User? @relation("BanActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([targetUserId, endsAt])
  @@index([type, createdAt])
}

model Subject {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String?
  color     String?
  gradeLevel GradeLevel
  order     Int      @default(0)

  courses   Course[]
  stats     UserSubjectStat[]
}

model UserSubjectStat {
  id         String  @id @default(cuid())
  userId     String
  subjectId  String
  totalXp    Int     @default(0)
  level      Int     @default(1)
  cardCount  Int     @default(0)

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
}

model Course {
  id              String   @id @default(cuid())
  subjectId       String
  title           String
  slug            String
  contentMarkdown String   @db.Text
  contentHtml     String?  @db.Text
  contentFormat   String   @default("HTML")
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  quizzes Quiz[]

  @@unique([subjectId, slug])
}

model Quiz {
  id           String     @id @default(cuid())
  courseId     String
  title        String
  type         QuizType   @default(QUIZ)
  timeLimitSec Int        @default(300)
  difficulty   Int        @default(1)
  passingScore Int        @default(50)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  Attempt[]
  duels     Duel[]
}

model Question {
  id      String       @id @default(cuid())
  quizId  String
  text    String       @db.Text
  type    QuestionType @default(QCM)
  points  Int          @default(1)
  order   Int          @default(0)

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]
}

model Answer {
  id         String  @id @default(cuid())
  questionId String
  text       String  @db.Text
  isCorrect  Boolean @default(false)
  order      Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Attempt {
  id             String    @id @default(cuid())
  userId         String
  quizId         String
  startedAt      DateTime  @default(now())
  expiresAt      DateTime
  completedAt    DateTime?
  scorePct       Int?
  correctCount   Int?
  totalQuestions Int?
  durationSec    Int?
  xpGained       Int?
  coinsGained    Int?
  answersJson    Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  source    XpSource
  amount    Int
  meta      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Cosmetic {
  id            String       @id @default(cuid())
  slug          String       @unique
  name          String
  type          CosmeticType
  description   String?
  priceCoins    Int          @default(0)
  requiredLevel Int          @default(1)
  assetUrl      String?
  borderClass   String?
  rarity        String       @default("common")

  ownedBy UserCosmetic[]
  purchases Purchase[]
  shopListings ShopListing[]
}

model UserCosmetic {
  id         String   @id @default(cuid())
  userId     String
  cosmeticId String
  acquiredAt DateTime @default(now())
  equipped   Boolean  @default(false)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmetic Cosmetic @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)

  @@unique([userId, cosmeticId])
}
